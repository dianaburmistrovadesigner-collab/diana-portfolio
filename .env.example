# Newsletter via Tally (recommended) — https://tally.so
# 1. Create a form with one Email field
# 2. Publish → Share → Embed → copy form id from tally.so/r/xxxxxxxx
# 3. Vercel → Settings → Environment Variables:
#    Name: VITE_TALLY_FORM_ID  |  Value: xxxxxxxx  (8 chars after /r/)
VITE_TALLY_FORM_ID=

# Optional Formspree fallback (only used if Tally id is empty)
VITE_NEWSLETTER_FORM_ACTION=
